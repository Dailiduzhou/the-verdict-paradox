# Base path for production builds (default: /)
# Set to /repo-name/ for GitHub Pages
# VITE_BASE=/the-verdict-paradox/

# Optional API origin for static hosting like Cloudflare Pages.
# Leave empty in local dev so Vite proxy/nginx continues to handle /v1 and /ws.
# VITE_API_BASE_URL=https://api.example.com

# Optional WebSocket origin when it is not served from the same host as the frontend.
# Leave empty in local dev so ws(s)://<current-host>/ws is used.
# VITE_WS_BASE_URL=wss://api.example.com
